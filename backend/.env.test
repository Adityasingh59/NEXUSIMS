# Backend Test Environment Configuration (for Railway deployment)
# Update these with actual Railway database and Redis URLs

ENVIRONMENT=production
DEBUG=false

# Database Configuration (Railway PostgreSQL)
# Get from Railway dashboard under database service
DATABASE_URL=postgresql+asyncpg://nexus_app:your_railway_db_password@your_railway_postgres_host:5432/nexus_ims

# Redis Configuration (Railway Redis)
# Get from Railway dashboard under Redis service
REDIS_URL=redis://your_railway_redis_password@your_railway_redis_host:6379/1
CELERY_BROKER_URL=redis://your_railway_redis_password@your_railway_redis_host:6379/0

# JWT Configuration
JWT_SECRET_KEY=your_test_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# CORS Configuration - Update with your Vercel test deployment URL
CORS_ORIGINS=["https://your-test-vercel-app.vercel.app", "http://localhost:3000", "http://localhost:5173"]

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Webhook Configuration
WEBHOOK_SECRET_KEY=your_test_webhook_secret_key
WEBHOOK_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
