# Frontend Test Environment Configuration (for Vercel deployment)
# Update with your Railway backend URL

# API Endpoint - Point to your Railway backend deployment
VITE_API_URL=https://your-railway-backend-url/api/v1

# Enable debugging in test environment (set to false in production)
VITE_DEBUG=true

# Optional: Analytics or monitoring
VITE_SENTRY_DSN=your-sentry-dsn-if-available
